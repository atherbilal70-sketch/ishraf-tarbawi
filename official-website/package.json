{
  "name": "ishraf-official-website",
  "version": "1.0.0",
  "private": true,
  "description": "الموقع الرسمي لمديرية الإشراف التربوي — وزارة التربية العراقية (المرحلة الأولى)",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i assets/css/tailwind.input.css -o assets/css/tailwind.css --minify",
    "watch:css": "tailwindcss -c tailwind.config.js -i assets/css/tailwind.input.css -o assets/css/tailwind.css --watch",
    "serve": "python3 -m http.server 8080"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0"
  }
}
